{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "meusite",
  "main": "worker.js",
  "compatibility_date": "2026-07-09",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": [
      "/wrangler.jsonc"
    ],
    "exclude": [
      "wrangler.jsonc",
      "worker.js"
    ],
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  }
}
